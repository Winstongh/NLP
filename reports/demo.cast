[0.004045, "o", "\u001b[1;33m基于 Transformer 的英译中机器翻译\u001b[0m\r\n\u001b[0;33mPyTorch 自实现 · 数据集 cmn-eng-simple (train 18000 / valid 500 / test 2636)\u001b[0m\r\n"]
[3.005317, "o", "\r\n\u001b[1;36m▶ 1) 自实现的 Transformer 源码\u001b[0m\r\n"]
[4.245419, "o", "config.py data.py evaluate.py inference.py __init__.py metrics.py model.py runtime.py tokenizer.py train.py translate.py vocab.py "]
[4.245863, "o", "\r\n"]
[7.749075, "o", "\r\n\u001b[1;36m▶ 2) 数据集样例（英文 → 中文，已分词）\u001b[0m\r\n"]
[8.954206, "o", "{\"src\": \"it 's none of your concern .\", \"tgt\": \"这不关 你 的 事 。\"}\r\n{\"src\": \"she has a habit of bi@@ ting her na@@ ils .\", \"tgt\": \"她 有 咬 指甲 的 习惯 。\"}\r\n"]
[12.955415, "o", "\r\n\u001b[1;36m▶ 3) 训练日志：loss 持续下降，valid_acc 从 0.13 升到 0.63\u001b[0m\r\n"]
[14.1612, "o", "Epoch 1: train_loss=8.3635, valid_loss=7.1584, valid_acc=0.1300, time=2.1s\r\nEpoch 5: train_loss=4.9140, valid_loss=4.7879, valid_acc=0.4204, time=1.9s\r\nEpoch 10: train_loss=3.8704, valid_loss=4.0187, valid_acc=0.5216, time=1.9s\r\nEpoch 20: train_loss=2.7948, valid_loss=3.6009, valid_acc=0.6009, time=1.8s\r\nEpoch 40: train_loss=2.1036, valid_loss=3.6367, valid_acc=0.6243, time=1.8s\r\nEpoch 60: train_loss=1.8874, valid_loss=3.6669, valid_acc=0.6329, time=1.8s\r\n"]
[18.665646, "o", "\r\n\u001b[1;36m▶ 4) 测试集评估结果（2636 句, beam search, 词级 BLEU）\u001b[0m\r\n"]
