[28.959398, "o", "   \u001b[0;37mEN:\u001b[0m  i like music .\r\n"]
[29.662823, "o", "   \u001b[1;32mZH:\u001b[0m  "]
[30.783938, "o", "我喜欢音乐。\r\n"]
[32.812477, "o", "   \u001b[0;37mEN:\u001b[0m  what time is it ?\r\n"]
[33.515965, "o", "   \u001b[1;32mZH:\u001b[0m  "]
[34.647952, "o", "几点了？\r\n"]
[36.67741, "o", "   \u001b[0;37mEN:\u001b[0m  she is reading a book .\r\n"]
[37.380987, "o", "   \u001b[1;32mZH:\u001b[0m  "]
